<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__col">
        {% render 'logo-inline', variant: 'on-dark' %}
        <p class="meta" style="margin-top: 24px; max-width: 38ch;">
          {{ section.settings.about | default: 'Componentes de prótese e órtese com curadoria técnica. Atendimento consultivo de quem entende do assunto.' }}
        </p>
        <div style="display:flex; gap:12px; margin-top:24px;">
          {%- if section.settings.instagram -%}<a href="{{ section.settings.instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>{%- endif -%}
          {%- if section.settings.whatsapp -%}<a href="https://wa.me/{{ section.settings.whatsapp | replace: '+', '' | replace: ' ', '' | replace: '-', '' }}" aria-label="WhatsApp">{% render 'icon', name: 'whatsapp' %}</a>{%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="site-footer__col">
        <h4>Contato</h4>
        <ul>
          <li class="meta">{{ section.settings.phone }}</li>
          <li class="meta">{{ section.settings.email }}</li>
          <li class="meta" style="margin-top:12px;">{{ section.settings.address }}</li>
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom">
      <span>© {{ 'now' | date: '%Y' }} minha prótese · CNPJ {{ section.settings.cnpj }}</span>
      <span>
        <a href="/policies/privacy-policy">Privacidade</a> ·
        <a href="/policies/terms-of-service">Termos</a> ·
        <a href="/policies/refund-policy">Trocas</a>
      </span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Rodapé",
  "settings": [
    { "type": "textarea", "id": "about", "label": "Descrição curta" },
    { "type": "text", "id": "phone", "label": "Telefone", "default": "+55 11 0000-0000" },
    { "type": "text", "id": "email", "label": "E-mail", "default": "contato@minhaprotese.com.br" },
    { "type": "textarea", "id": "address", "label": "Endereço" },
    { "type": "text", "id": "cnpj", "label": "CNPJ" },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "text", "id": "whatsapp", "label": "WhatsApp (com DDI)", "default": "+5511000000000" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Coluna de links",
      "settings": [
        { "type": "text", "id": "heading", "label": "Título", "default": "Categorias" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_column", "settings": { "heading": "Categorias" } },
      { "type": "link_column", "settings": { "heading": "Atendimento" } }
    ]
  }
}
{% endschema %}
