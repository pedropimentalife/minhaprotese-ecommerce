{%- comment -%}
  Ícones outline 1.75px, estilo Feather/Lucide.
  Uso: {% render 'icon', name: 'search' %}
{%- endcomment -%}
{%- assign s = 20 -%}
{%- if size != blank -%}{%- assign s = size -%}{%- endif -%}
<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {%- case name -%}
  {%- when 'search' -%}
    <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
  {%- when 'user' -%}
    <path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/>
  {%- when 'bag' -%}
    <path d="M6 7h12l-1 14H7L6 7z"/><path d="M9 7a3 3 0 0 1 6 0"/>
  {%- when 'menu' -%}
    <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
  {%- when 'close' -%}
    <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
  {%- when 'whatsapp' -%}
    <path d="M3 21l1.65-4.94A8 8 0 1 1 8 19.55L3 21z"/><path d="M8.5 9.5c.5 2 2 3.5 4 4l1.2-1.2a1 1 0 0 1 1-.25l2.3.77a1 1 0 0 1 .65 1.16l-.3 1.4a1 1 0 0 1-.94.78A8.5 8.5 0 0 1 8.5 9.5a1 1 0 0 1 .78-.94l1.4-.3a1 1 0 0 1 1.16.65l.77 2.3a1 1 0 0 1-.25 1L11.16 13.4"/>
  {%- when 'shield' -%}
    <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><path d="m9 12 2 2 4-4"/>
  {%- when 'truck' -%}
    <path d="M3 7h12v9H3z"/><path d="M15 10h4l2 3v3h-6"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/>
  {%- when 'headphones' -%}
    <path d="M3 18v-7a9 9 0 0 1 18 0v7"/><path d="M3 15h3v6H4a1 1 0 0 1-1-1v-5z"/><path d="M21 15h-3v6h2a1 1 0 0 0 1-1v-5z"/>
  {%- when 'leaf' -%}
    <path d="M11 20A7 7 0 0 1 4 13c0-4 3-9 9-9 0 4-1 7-4 10s-7 6-11 6"/>
  {%- when 'instagram' -%}
    <rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
  {%- when 'chevron-down' -%}
    <polyline points="6 9 12 15 18 9"/>
  {%- when 'chevron-right' -%}
    <polyline points="9 6 15 12 9 18"/>
  {%- when 'plus' -%}
    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
  {%- when 'minus' -%}
    <line x1="5" y1="12" x2="19" y2="12"/>
  {%- when 'check' -%}
    <polyline points="4 12 10 18 20 6"/>
  {%- endcase -%}
</svg>
