{%- comment -%}
  Logo inline SVG. variant: 'on-dark' para fundos escuros.
{%- endcomment -%}
{%- assign teal_arc = '#14B4B4' -%}
{%- assign limb     = '#1F262B' -%}
{%- assign label    = '#1F262B' -%}
{%- assign pivot_bg = '#FAF6F0' -%}
{%- if variant == 'on-dark' -%}
  {%- assign teal_arc = '#46C4C4' -%}
  {%- assign limb     = '#FAF6F0' -%}
  {%- assign label    = '#FAF6F0' -%}
  {%- assign pivot_bg = '#1F262B' -%}
{%- endif -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 520 120" role="img" aria-label="minha prótese">
  <g transform="translate(0,8)">
    <path d="M14 84 A 50 50 0 0 1 96 30" fill="none" stroke="{{ teal_arc }}" stroke-width="6" stroke-linecap="round"/>
    <line x1="58" y1="22" x2="92" y2="60" stroke="{{ limb }}" stroke-width="10" stroke-linecap="round"/>
    <line x1="92" y1="60" x2="76" y2="100" stroke="{{ limb }}" stroke-width="10" stroke-linecap="round"/>
    <circle cx="92" cy="60" r="9" fill="{{ pivot_bg }}" stroke="{{ teal_arc }}" stroke-width="4"/>
    <circle cx="92" cy="60" r="2.5" fill="#F09020"/>
  </g>
  <g transform="translate(130,72)" font-family="Lexend, sans-serif" font-weight="600">
    <text x="0" y="0" font-size="44" letter-spacing="-1.2" fill="{{ label }}">minha</text>
    <circle cx="148" cy="-12" r="4.5" fill="#F09020"/>
    <text x="164" y="0" font-size="44" letter-spacing="-1.2" fill="{{ label }}">prótese</text>
  </g>
</svg>
