{%- comment -%}
  Botão flutuante de WhatsApp com painel de chat IA.
  O painel abre uma janela com um chat preview (front-end) que envia mensagens para
  um endpoint configurável (settings.ai_endpoint). Quando o endpoint não estiver definido,
  o botão "Falar agora" abre WhatsApp diretamente.
{%- endcomment -%}
{%- assign whatsapp_raw = settings.whatsapp_number | default: '+5511000000000' -%}
{%- assign whatsapp_clean = whatsapp_raw | replace: '+', '' | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' -%}

<div id="mp-chat" class="mp-chat" data-whatsapp="{{ whatsapp_clean }}" data-ai-endpoint="{{ settings.ai_endpoint }}">
  <button type="button" class="mp-chat__fab" aria-label="Abrir conversa" data-mp-toggle>
    {% render 'icon', name: 'whatsapp', size: 28 %}
    <span class="mp-chat__fab-label">Tirar dúvida</span>
  </button>

  <div class="mp-chat__panel" role="dialog" aria-label="Conversa minha prótese" aria-hidden="true" data-mp-panel>
    <header class="mp-chat__header">
      <div style="display:flex; align-items:center; gap:12px;">
        <span class="mp-chat__avatar">
          {% render 'icon', name: 'headphones', size: 18 %}
        </span>
        <div>
          <strong style="display:block; font-size:14px; color:#fff;">Atendimento minha prótese</strong>
          <span style="font-size:12px; color: rgba(255,255,255,0.7);">Em média respondemos em 2 min</span>
        </div>
      </div>
      <button type="button" class="mp-chat__close" aria-label="Fechar" data-mp-toggle>
        {% render 'icon', name: 'close', size: 18 %}
      </button>
    </header>

    <div class="mp-chat__messages" data-mp-messages>
      <div class="mp-chat__msg mp-chat__msg--in">
        Oi! Aqui é a equipe da <em>minha prótese</em>. Conta pra gente o que você está procurando — pode falar do componente, do paciente ou da prescrição.
      </div>
    </div>

    <form class="mp-chat__form" data-mp-form>
      <input
        class="mp-chat__input"
        type="text"
        name="message"
        placeholder="Escreva sua mensagem"
        autocomplete="off"
        aria-label="Mensagem"
        required>
      <button type="submit" class="mp-chat__send btn btn--whatsapp btn--sm">Enviar</button>
    </form>

    <div class="mp-chat__cta">
      <a id="mp-chat-wa-link" href="https://wa.me/{{ whatsapp_clean }}" target="_blank" rel="noopener" class="btn btn--whatsapp btn--block">
        {% render 'icon', name: 'whatsapp', size: 18 %} Falar no WhatsApp agora
      </a>
    </div>
  </div>
</div>

<style>
  .mp-chat { position: fixed; right: 20px; bottom: 20px; z-index: 90; font-family: var(--font-sans); }
  .mp-chat__fab {
    display: inline-flex; align-items: center; gap: 8px;
    height: 56px; padding: 0 20px 0 16px;
    background: var(--brand-orange-500);
    color: #fff; border: 0; border-radius: var(--r-pill);
    font-weight: 600; font-size: 14px;
    box-shadow: 0 12px 28px rgba(240,144,32,0.32);
    transition: transform 200ms var(--ease), box-shadow 200ms var(--ease);
  }
  .mp-chat__fab:hover { transform: translateY(-2px); box-shadow: 0 16px 36px rgba(240,144,32,0.4); }
  .mp-chat__fab-label { white-space: nowrap; }
  @media (max-width: 480px) {
    .mp-chat__fab-label { display: none; }
    .mp-chat__fab { width: 56px; height: 56px; padding: 0; border-radius: 50%; justify-content: center; }
  }

  .mp-chat__panel {
    position: absolute; right: 0; bottom: 76px;
    width: 360px; max-width: calc(100vw - 40px);
    background: #fff; border-radius: 16px;
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: none;
    flex-direction: column;
    max-height: 70vh;
  }
  .mp-chat.is-open .mp-chat__panel { display: flex; }
  .mp-chat__header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 18px;
    background: var(--warm-charcoal);
    color: #fff;
  }
  .mp-chat__avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--brand-teal-500); color: #fff;
    display: grid; place-items: center;
  }
  .mp-chat__close { background: transparent; border: 0; color: #fff; padding: 6px; border-radius: 6px; }
  .mp-chat__close:hover { background: rgba(255,255,255,0.1); }
  .mp-chat__messages {
    flex: 1; padding: 18px; overflow-y: auto;
    background: var(--warm-cream);
    display: flex; flex-direction: column; gap: 10px;
    min-height: 200px;
  }
  .mp-chat__msg {
    max-width: 80%; padding: 10px 14px;
    border-radius: 12px; font-size: 14px; line-height: 1.45;
  }
  .mp-chat__msg em { font-family: var(--font-italic); font-style: italic; color: var(--brand-teal-600); font-weight: 500; }
  .mp-chat__msg--in  { background: #fff; align-self: flex-start; color: var(--brand-slate-700); border: 1px solid var(--brand-slate-200); }
  .mp-chat__msg--out { background: var(--brand-teal-500); align-self: flex-end; color: #fff; }
  .mp-chat__msg--typing { color: var(--brand-slate-500); font-style: italic; }
  .mp-chat__form { display: flex; gap: 8px; padding: 12px; border-top: 1px solid var(--brand-slate-200); }
  .mp-chat__input {
    flex: 1; height: 40px; padding: 0 12px;
    border: 1px solid var(--brand-slate-200); border-radius: 10px;
    font: inherit;
  }
  .mp-chat__input:focus { outline: none; border-color: var(--brand-teal-500); }
  .mp-chat__cta { padding: 0 12px 12px; }
</style>

<script>
(function () {
  var chat = document.getElementById('mp-chat');
  if (!chat) return;
  var panel = chat.querySelector('[data-mp-panel]');
  var msgs  = chat.querySelector('[data-mp-messages]');
  var form  = chat.querySelector('[data-mp-form]');
  var input = form.querySelector('input[name="message"]');
  var waLink = document.getElementById('mp-chat-wa-link');
  var waNum = chat.getAttribute('data-whatsapp');
  var aiEndpoint = chat.getAttribute('data-ai-endpoint');

  function toggle () {
    var open = chat.classList.toggle('is-open');
    panel.setAttribute('aria-hidden', open ? 'false' : 'true');
    if (open) setTimeout(function () { input.focus(); }, 60);
  }

  chat.querySelectorAll('[data-mp-toggle]').forEach(function (b) { b.addEventListener('click', toggle); });

  function append (text, dir, opts) {
    opts = opts || {};
    var d = document.createElement('div');
    d.className = 'mp-chat__msg mp-chat__msg--' + dir + (opts.typing ? ' mp-chat__msg--typing' : '');
    d.textContent = text;
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
    return d;
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var text = input.value.trim();
    if (!text) return;
    append(text, 'out');
    input.value = '';

    // Atualiza link do WhatsApp com a mensagem pré-preenchida
    waLink.href = 'https://wa.me/' + waNum + '?text=' + encodeURIComponent(text);

    var typing = append('digitando...', 'in', { typing: true });

    if (aiEndpoint) {
      fetch(aiEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, page: window.location.pathname })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          typing.remove();
          append(data.reply || 'Recebido. Logo te respondemos pelo WhatsApp.', 'in');
        })
        .catch(function () {
          typing.remove();
          append('No momento estamos sem conexão com o assistente. Toque em "Falar no WhatsApp agora" abaixo que te respondemos por lá.', 'in');
        });
    } else {
      // Fallback sem IA: orienta para WhatsApp humano
      setTimeout(function () {
        typing.remove();
        append('Recebemos sua mensagem. Para uma resposta na hora, toque em "Falar no WhatsApp agora" abaixo.', 'in');
      }, 800);
    }
  });
})();
</script>
